# -------------------------
# Pneumonia: EfficientNetB0 transfer learning (C3)
# - If dataset exists at DATA_ROOT (after Kaggle unzip), train/fine-tune.
# - Otherwise create a demo EfficientNet model (random init) so UI works.
# -------------------------
IMG_SIZE = (224, 224)
PNEUMONIA_MODEL = None
PNEUMONIA_MODEL_PATH = "pneumonia_efficientnetb0.h5"
DATA_ROOT = "/content/chest_xray_dataset/chest_xray"  # default Kaggle unzip location

def build_efficientnet_model(trainable_backbone=False):
    backbone = EfficientNetB0(include_top=False, weights='imagenet', input_shape=(IMG_SIZE[0], IMG_SIZE[1], 3), pooling='avg')
    backbone.trainable = trainable_backbone
    x = backbone.output
    x = layers.Dense(256, activation='relu')(x)
    x = layers.Dropout(0.4)(x)
    out = layers.Dense(1, activation='sigmoid')(x)
    model = models.Model(inputs=backbone.input, outputs=out)
    model.compile(optimizer=optimizers.Adam(1e-4), loss='binary_crossentropy', metrics=['accuracy'])
    return model

def prepare_pneumonia_dataset(data_root, img_size=IMG_SIZE, batch_size=16):
    # Read train/val/test as in Kaggle chest-xray-pneumonia
    import glob
    AUTOTUNE = tf.data.AUTOTUNE
    train_paths, train_labels = [], []
    val_paths, val_labels = [], []
    test_paths, test_labels = [], []
    for split in ['train','val','test']:
        for cls in ['PNEUMONIA','NORMAL']:
            pattern = os.path.join(data_root, split, cls, '*')
            for p in glob.glob(pattern):
                if split=='train':
                    train_paths.append(p); train_labels.append(1 if cls=='PNEUMONIA' else 0)
                elif split=='val':
                    val_paths.append(p); val_labels.append(1 if cls=='PNEUMONIA' else 0)
                else:
                    test_paths.append(p); test_labels.append(1 if cls=='PNEUMONIA' else 0)
    def _read(path, label, augment=False):
        path = path.decode('utf-8')
        img = cv2.imread(path, cv2.IMREAD_GRAYSCALE)
        if img is None:
            img = cv2.imread(path, cv2.IMREAD_COLOR)
            img = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        img = cv2.resize(img, img_size)
        # to 3 channels
        img = np.stack([img, img, img], axis=-1)
        if augment:
            # simple augmentations
            img = tf.image.random_flip_left_right(img)
            img = tf.image.random_brightness(img, max_delta=0.1)
        img = eff_preprocess(img)  # EfficientNet preprocess (expects float)
        return img, np.float32(label) # Cast label to float32
    def make_ds(paths, labels, augment=False):
        ds = tf.data.Dataset.from_tensor_slices((paths, labels))
        if augment:
            ds = ds.shuffle(2048)
        def _map(p,l):
            img, lab = tf.py_function(_read, inp=[p,l,augment], Tout=[tf.float32, tf.float32]) # Expect float32 label
            img.set_shape((img_size[0], img_size[1], 3))
            lab.set_shape(())
            return img, lab
        ds = ds.map(_map, num_parallel_calls=AUTOTUNE).batch(batch_size).prefetch(AUTOTUNE)
        return ds
    train_ds = make_ds(train_paths, train_labels, augment=True)
    val_ds = make_ds(val_paths, val_labels, augment=False)
    test_ds = make_ds(test_paths, test_labels, augment=False)
    return train_ds, val_ds, test_ds

def try_prepare_and_train_pneumonia(data_root=DATA_ROOT):
    global PNEUMONIA_MODEL
    if os.path.exists(data_root):
        # check there is reasonable data
        import glob
        sample_train = glob.glob(os.path.join(data_root, 'train', 'PNEUMONIA', '*'))
        if len(sample_train) < 20:
            print("Dataset present but small (<20). Skipping full train; building demo EfficientNet model.")
        else:
            print("Preparing dataset from", data_root)
            train_ds, val_ds, test_ds = prepare_pneumonia_dataset(data_root, img_size=IMG_SIZE, batch_size=16)
            print("Building EfficientNetB0 (backbone frozen -> train top, then unfreeze last blocks).")
            model = build_efficientnet_model(trainable_backbone=False)
            # train top
            callbacks = [tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True),
                         tf.keras.callbacks.ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=2)]
            model.fit(train_ds, validation_data=val_ds, epochs=6, callbacks=callbacks, verbose=1)
            # optionally fine-tune a few layers
            print("Fine-tuning: unfreezing top backbone layers.")
            for layer in model.layers:
                layer.trainable = True
            model.compile(optimizer=optimizers.Adam(1e-5), loss='binary_crossentropy', metrics=['accuracy'])
            model.fit(train_ds, validation_data=val_ds, epochs=4, callbacks=callbacks, verbose=1)
            model.save(PNEUMONIA_MODEL_PATH)
            PNEUMONIA_MODEL = model
            print("Pneumonia EfficientNet model trained and saved.")
            return
    # no dataset -> create demo model so UI runs
    print("No full pneumonia dataset found at", data_root, "- creating Demo EfficientNet model (untrained top).")
    PNEUMONIA_MODEL = build_efficientnet_model(trainable_backbone=False)
    try:
        PNEUMONIA_MODEL.save(PNEUMONIA_MODEL_PATH)
    except Exception:
        pass

try_prepare_and_train_pneumonia()

# if model file exists and PNEUMONIA_MODEL not loaded, try load it
if os.path.exists(PNEUMONIA_MODEL_PATH) and PNEUMONIA_MODEL is None:
    try:
        PNEUMONIA_MODEL = tf.keras.models.load_model(PNEUMONIA_MODEL_PATH)
    except Exception:
        PNEUMONIA_MODEL = build_efficientnet_model(trainable_backbone=False)

MODELS['Pneumonia'] = PNEUMONIA_MODEL

# -------------------------
# Grad-CAM (H3 soft purple) helpers
# -------------------------
def find_last_conv_layer(m):
    # EfficientNetB0 commonly has a layer named 'top_conv' as last conv, but we find the last Conv2D robustly
    for layer in reversed(m.layers):
        if isinstance(layer, layers.Conv2D):
            return layer.name
    return None

def make_gradcam_heatmap(img_array, model, last_conv_layer_name=None):
    # img_array expected shape (1,H,W,3) and already preprocessed by eff_preprocess (float)
    if last_conv_layer_name is None:
        last_conv_layer_name = find_last_conv_layer(model)
    last_conv = model.get_layer(last_conv_layer_name)
    grad_model = tf.keras.models.Model([model.inputs], [last_conv.output, model.output])
    with tf.GradientTape() as tape:
        conv_outputs, predictions = grad_model(img_array)
        loss = predictions[:, 0]
    grads = tape.gradient(loss, conv_outputs)
    pooled_grads = tf.reduce_mean(grads, axis=(0,1,2))
    conv_outputs = conv_outputs[0]
    heatmap = conv_outputs @ pooled_grads[..., tf.newaxis]
    heatmap = tf.squeeze(heatmap)
    heatmap = tf.maximum(heatmap, 0) / (tf.reduce_max(heatmap) + 1e-10)
    return heatmap.numpy()

def apply_purple_overlay(original_img_rgb, heatmap, alpha=0.5):
    # original_img_rgb: HxWx3 in 0..1 range (RGB); heatmap: HxW 0..1
    heatmap_resized = cv2.resize(heatmap, (original_img_rgb.shape[1], original_img_rgb.shape[0]))
    cmap = cm.get_cmap('Purples')
    heatmap_rgba = cmap(heatmap_resized)[:, :, :3]
    blended = (1-alpha) * original_img_rgb + alpha * heatmap_rgba
    blended = np.clip(blended, 0, 1)
    return blended

def predict_pneumonia_and_cam(img_input):
    """
    img_input: numpy array (H,W,3) in uint8 or float 0..255/0..1, may be grayscale or RGB
    returns: prob (0..1), resized_img (0..1), heatmap, blended (0..1)
    """
    img = img_input.copy()
    # convert grayscale to RGB if needed
    if img.ndim == 2:
        img = np.stack([img, img, img], axis=-1)
    if img.shape[2] == 4:
        img = img[..., :3]
    # to float
    if img.dtype != np.float32:
        img = img.astype('float32') / 255.0
    resized = cv2.resize(img, IMG_SIZE)
    # EfficientNet expects preprocess_input
    inp = np.expand_dims(resized*255.0, axis=0)  # eff_preprocess expects values in [0,255]
    inp = eff_preprocess(inp)
    prob = float(MODELS['Pneumonia'].predict(inp, verbose=0)[0][0])
    heatmap = make_gradcam_heatmap(inp, MODELS['Pneumonia'])
    blended = apply_purple_overlay(resized, heatmap, alpha=0.55)
    return prob, resized, heatmap, blended

# -------------------------
# Unified prediction wrapper combining tabular & image flows
# -------------------------
def predict_unified(disease_choice, image_input, *numeric_inputs):
    """
    disease_choice: 'Diabetes', 'Heart Disease', 'Pneumonia'
    image_input: numpy array (or None) from Gradio image input
    numeric_inputs: MAX_FEATURES floats (for tabular cases)
    Return:
      - if pneumonia: (blended_image_uint8, html_result)
      - else: (None, html_result)
    """
    if disease_choice not in FEATURE_MAP:
        return None, "<b style='color:red'>Select valid disease</b>"

    if disease_choice == 'Pneumonia':
        if image_input is None:
            return None, "<b style='color:red'>Upload chest X-ray image.</b>"
        prob, resized, heatmap, blended = predict_pneumonia_and_cam(image_input)
        pct = prob * 100.0
        if prob > 0.7:
            color = "red"; msg = f"PNEUMONIA DETECTED — {pct:.1f}%"
        elif prob > 0.4:
            color = "orange"; msg = f"POSSIBLE PNEUMONIA — {pct:.1f}%"
        else:
            color = "green"; msg = f"Likely Normal — {pct:.1f}%"
        html = f"<div style='padding:8px;border-radius:8px;border:2px solid {color};color:{color};font-weight:700'>{msg}</div>"
        blended_uint8 = (blended * 255).astype('uint8')
        return blended_uint8, html

    # Tabular cases
    n_req = FEATURE_MAP[disease_choice]['count']
    try:
        # Gradio ordering will be [disease_dropdown, image_input, feature1, feature2, ...]
        numeric_vals = np.array(numeric_inputs[:MAX_FEATURES], dtype=float)[:n_req].reshape(1, -1)
    except Exception as e:
        return None, f"<b style='color:red'>Input conversion error: {e}</b>"

    scaler = SCALERS.get(disease_choice, None)
    if scaler is not None:
        numeric_vals = scaler.transform(numeric_vals)

    model = MODELS.get(disease_choice)
    if model is None:
        return None, "<b style='color:red'>Model not available.</b>"

    prob = float(model.predict(numeric_vals, verbose=0)[0][0])
    pct = prob * 100.0
    if prob > 0.7:
        color = "red"; msg = f"HIGH RISK — {pct:.1f}%"
    elif prob > 0.4:
        color = "orange"; msg = f"MODERATE RISK — {pct:.1f}%"
    else:
        color = "green"; msg = f"LOW RISK — {pct:.1f}%"
    html = f"<div style='padding:8px;border-radius:8px;border:2px solid {color};color:{color};font-weight:700'>{msg}</div>"
    # Return None for image output and html text
    return None, html

# -------------------------
# Gradio UI (single app)
# - Numeric inputs created for MAX_FEATURES
# - Image input for Pneumonia shown only when Pneumonia selected
# -------------------------
feature_inputs = []
for i in range(MAX_FEATURES):
    feature_inputs.append(gr.Number(label=f"Feature {i+1}", value=0.0, visible=True, precision=3, elem_id=f"feature_{i+1}"))

image_input = gr.Image(type="numpy", label="Upload Chest X-ray (Pneumonia)", visible=False)

def update_ui_for_choice(choice):
    updates = []
    if choice not in FEATURE_MAP:
        for _ in range(MAX_FEATURES):
            updates.append(gr.update(visible=False, value=0.0))
        updates.append(gr.update(visible=False))
        return updates
    if choice == 'Pneumonia':
        for _ in range(MAX_FEATURES):
            updates.append(gr.update(visible=False, value=0.0))
        updates.append(gr.update(visible=True))
        return updates
    # tabular disease chosen
    names = FEATURE_MAP[choice]['names']
    n_req = FEATURE_MAP[choice]['count']
    for i in range(MAX_FEATURES):
        if i < n_req:
            # placeholder examples
            fname = names[i]
            example = 0.0
            if 'Age' in fname:
                example = 45
            elif 'Sex' in fname:
                example = 1
            elif 'Glucose' in fname or 'Cholesterol' in fname:
                example = 120
            elif 'BMI' in fname:
                example = 26.5
            elif 'Pregnancies' in fname:
                example = 2
            updates.append(gr.update(visible=True, label=names[i], value=example))
        else:
            updates.append(gr.update(visible=False, value=0.0))
    updates.append(gr.update(visible=False))  # hide image
    return updates

# Build Blocks UI
custom_css = """
.gradio-container { background: #0b1220; color: #f7fafc; }
.gr-button-primary { background-color: #5d9cec !important; color: white !important; }
"""

with gr.Blocks(css=custom_css) as demo:
    gr.Markdown("<h2 style='text-align:center;color:#9fbff5'>Hybrid Medical Predictor — Diabetes, Heart (tabular) + Pneumonia (image)</h2>")
    gr.Markdown("<i>Educational demo only. Not for clinical use.</i>")

    with gr.Row():
        disease_dropdown = gr.Dropdown(choices=list(FEATURE_MAP.keys()), value="Diabetes", label="Select Disease Model")
        result_html = gr.HTML("<i>Enter features OR upload an image and click RUN.</i>", label="Prediction Result")

    with gr.Column():
        gr.Markdown("### Inputs (only relevant fields appear)")
        for i in range(0, MAX_FEATURES, 2):
            with gr.Row():
                feature_inputs[i].render()
                if i+1 < MAX_FEATURES:
                    feature_inputs[i+1].render()
        image_input.render()
        run_btn = gr.Button("RUN ANALYSIS", variant="primary")

    # wire UI events
    disease_dropdown.change(fn=update_ui_for_choice, inputs=[disease_dropdown], outputs=feature_inputs + [image_input])
    # order inputs for predict_unified: disease, image_input, feature_inputs...
    run_btn.click(fn=predict_unified, inputs=[disease_dropdown, image_input] + feature_inputs, outputs=[gr.Image(type="numpy", label="Overlay (if any)"), result_html])
    demo.load(fn=update_ui_for_choice, inputs=[disease_dropdown], outputs=feature_inputs + [image_input])

print("DISCLAIMER: Educational demo only — not for medical diagnosis.")
demo.launch(share=True)
