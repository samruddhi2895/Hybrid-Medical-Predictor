np.random.seed(42)
# Diabetes
X_d, y_d = make_classification(n_samples=1000, n_features=FEATURE_MAP["Diabetes"]["count"],
                               n_informative=FEATURE_MAP["Diabetes"]["count"] - 2, random_state=1) # Adjusted n_informative
sc_d = StandardScaler().fit(X_d)
X_d = sc_d.transform(X_d)
