X_train_d, X_val_d, y_train_d, y_val_d = train_test_split(X_d, y_d, test_size=0.2, random_state=42)

# Heart
X_h, y_h = make_classification(n_samples=1000, n_features=FEATURE_MAP["Heart Disease"]["count"],
