}

MAX_FEATURES = max([v["count"] for k, v in FEATURE_MAP.items() if v["count"] > 0])

# Globals
MODELS = {name: None for name in FEATURE_MAP.keys()}
SCALERS = {}

# -------------------------
# Simulate tabular datasets (demo) — replace with real CSV loading if available
