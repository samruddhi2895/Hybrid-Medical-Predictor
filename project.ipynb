# -------------------------
# Tabular ANN builder + Optuna objective
# -------------------------
def create_ann(input_dim, n_layers=2, n_neurons=64, dropout_rate=0.2, learning_rate=1e-3):
    model = Sequential()
    model.add(layers.Input(shape=(input_dim,)))
    model.add(layers.Dense(n_neurons, activation='relu'))
    for _ in range(max(0, n_layers-1)):
        model.add(layers.Dense(n_neurons, activation='relu'))
        model.add(layers.Dropout(dropout_rate))
    model.add(layers.Dense(1, activation='sigmoid'))
    model.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=learning_rate),
                  loss='binary_crossentropy', metrics=['accuracy'])
    return model

def objective_generic(trial, X_train, y_train, X_val, y_val, input_dim, epochs=12, batch_size=32):
    n_layers = trial.suggest_int('n_layers', 1, 3)
    n_neurons = trial.suggest_int('n_neurons', 32, 128, step=32)
    dropout_rate = trial.suggest_float('dropout_rate', 0.0, 0.5)
    lr = trial.suggest_loguniform('learning_rate', 1e-4, 1e-2)
    model = create_ann(input_dim, n_layers=n_layers, n_neurons=n_neurons, dropout_rate=dropout_rate, learning_rate=lr)
    early = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True)
    # Explicitly cast data to float32
    history = model.fit(X_train.astype(np.float32), y_train.astype(np.float32), validation_data=(X_val.astype(np.float32), y_val.astype(np.float32)), epochs=epochs, batch_size=batch_size, verbose=0, callbacks=[early])
    val_acc = history.history.get('val_accuracy', [0.0])[-1]
    return val_acc

# Run Optuna (demo small n_trials)
N_TRIALS = 6
print("Running Optuna (demo) for tabular models...")
# Diabetes
study_d = optuna.create_study(direction='maximize')
study_d.optimize(lambda t: objective_generic(t, X_train_d, y_train_d, X_val_d, y_val_d, FEATURE_MAP['Diabetes']['count']), n_trials=N_TRIALS)
best_d = study_d.best_params
MODELS['Diabetes'] = create_ann(FEATURE_MAP['Diabetes']['count'], **best_d)
MODELS['Diabetes'].fit(X_d, y_d, epochs=20, batch_size=32, verbose=0)
print("Diabetes model ready.")

# Heart
study_h = optuna.create_study(direction='maximize')
study_h.optimize(lambda t: objective_generic(t, X_train_h, y_train_h, X_val_h, y_val_h, FEATURE_MAP['Heart Disease']['count']), n_trials=N_TRIALS)
best_h = study_h.best_params
MODELS['Heart Disease'] = create_ann(FEATURE_MAP['Heart Disease']['count'], **best_h)
MODELS['Heart Disease'].fit(X_h, y_h, epochs=25, batch_size=64, verbose=0)
